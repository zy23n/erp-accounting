server:
  port: 8080

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/erp_accounting?serverTimezone=Asia/Seoul
    username: ${DB_USERNAME} # MySQL 계정명
    password: ${DB_PASSWORD} # MySQL 비밀번호
    driver-class-name: com.mysql.cj.jdbc.Driver

  jpa:
    hibernate:
      ddl-auto: update
    show-sql: true

jwt:
  secret: ${JWT_SECRET} # JWT Secret Key